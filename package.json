  "description": "读取本机 Codex 和 Claude Code 历史使用数据并生成使用报告",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "ai-usage": "src/cli/main.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun test && bunx tsc --noEmit",
    "dev": "bun run src/cli/main.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
